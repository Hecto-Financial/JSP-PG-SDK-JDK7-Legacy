<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">


	<appender name="A1"
		class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>C:/npg/java/trans.log</file>
		<rollingPolicy
			class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>C:/npg/java/trans.log.%d{yyyy-MM-dd}.log
			</fileNamePattern>
		</rollingPolicy>
		<encoder>
			<pattern>%d{yyyy/MM/dd HH:mm:ss.SSS}%X[%t][%p][%F:%L] : %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="A2"
		class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>C:/npg/java/notiTrans.log</file>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>C:/npg/java/notiTrans.log.%d{yyyy-MM-dd}.log
			</fileNamePattern>
		</rollingPolicy>
		<encoder>
			<pattern>%d{yyyy/MM/dd HH:mm:ss.SSS}%X[%t][%p][%F:%L] : %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="CONSOLE"
		class="ch.qos.logback.core.ConsoleAppender">
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>%d{yyyy/MM/dd HH:mm:ss.SSS}%X[%t][%p][%F:%L] : %msg%n</pattern>
		</encoder>
	</appender>

	<logger name="trans" level="INFO" additivity="TRUE">
		<appender-ref ref="A1" />
	</logger>

	<logger name="notiTrans" level="INFO" additivity="TRUE">
		<appender-ref ref="A2" />
	</logger>

	<root level="INFO">
		<appender-ref ref="CONSOLE" />
	</root>
</configuration>